{
  "playbook_id": "containment.core",
  "name": "Core Containment",
  "version": "1.0",
  "actions": [
    {
      "action": "block_ip",
      "description": "Simulate blocking a suspicious IP address at the edge.",
      "simulation_only": true,
      "resolves_incident": true,
      "status_on_success": "mitigated",
      "escalation_threshold": 75.0,
      "blast_radius_multiplier": 1.1,
      "params": [
        {
          "name": "target_ip",
          "type": "string",
          "required": true,
          "description": "IPv4 or IPv6 address to block."
        },
        {
          "name": "duration_minutes",
          "type": "integer",
          "required": false,
          "default": 60,
          "description": "How long the simulated block lasts."
        }
      ]
    },
    {
      "action": "isolate_host",
      "description": "Simulate isolating a host from the network.",
      "simulation_only": true,
      "resolves_incident": true,
      "status_on_success": "mitigated",
      "escalation_threshold": 60.0,
      "blast_radius_multiplier": 1.4,
      "params": [
        {
          "name": "host_id",
          "type": "string",
          "required": true,
          "description": "Host identifier to isolate."
        },
        {
          "name": "reason",
          "type": "string",
          "required": false,
          "default": "detector escalation",
          "description": "Analyst-friendly reason for the action."
        }
      ]
    },
    {
      "action": "snapshot",
      "description": "Simulate evidence preservation before stronger containment.",
      "simulation_only": true,
      "resolves_incident": false,
      "status_on_success": "investigating",
      "escalation_threshold": 85.0,
      "blast_radius_multiplier": 0.7,
      "params": [
        {
          "name": "artifact_type",
          "type": "string",
          "required": false,
          "default": "memory",
          "description": "Artifact type to preserve."
        }
      ]
    }
  ]
}
