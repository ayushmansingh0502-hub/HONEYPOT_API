{
  "playbook_id": "identity.response",
  "name": "Identity Response",
  "version": "1.0",
  "actions": [
    {
      "action": "revoke_session",
      "description": "Simulate revoking a suspicious user session.",
      "simulation_only": true,
      "resolves_incident": true,
      "status_on_success": "mitigated",
      "escalation_threshold": 65.0,
      "blast_radius_multiplier": 1.0,
      "params": [
        {
          "name": "session_id",
          "type": "string",
          "required": true,
          "description": "Session identifier to revoke."
        },
        {
          "name": "notify_user",
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Whether to notify the affected user."
        }
      ]
    },
    {
      "action": "disable_user",
      "description": "Simulate disabling a compromised user account.",
      "simulation_only": true,
      "resolves_incident": false,
      "status_on_success": "investigating",
      "escalation_threshold": 55.0,
      "blast_radius_multiplier": 1.6,
      "params": [
        {
          "name": "user_id",
          "type": "string",
          "required": true,
          "description": "User identifier to disable."
        },
        {
          "name": "ticket_reference",
          "type": "string",
          "required": false,
          "default": "pending-review",
          "description": "Linked ticket or case reference."
        }
      ]
    }
  ]
}
